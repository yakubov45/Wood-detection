{
  "version": 2,
  "name": "yogoch-nuqson-aniqlovchi",
  "routes": [
    {
      "src": "/tfjs_model/(.+)\\.bin",
      "dest": "/tfjs_model/$1.bin",
      "headers": {
        "Content-Type": "application/octet-stream",
        "Cache-Control": "public, max-age=604800",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/tfjs_model/(.+)\\.json",
      "dest": "/tfjs_model/$1.json",
      "headers": {
        "Content-Type": "application/json",
        "Cache-Control": "public, max-age=604800",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
